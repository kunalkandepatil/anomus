{
  "name": "anomus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch --import tsx/esm server/index.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "concurrently \"npm run dev:server\" \"npm run preview\""
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@unbrn/ui": "file:../ui",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "~5.8.0",
    "vite": "^6.3.0"
  }
}